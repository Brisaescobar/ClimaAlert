@startuml

participant AlertScheduler as S2
participant WeatherService as WS
participant WeatherDataRepository as REPO
participant AlertService as AS
participant "JavaMailSender (SMTP)" as MAIL

loop cada 1 minuto
    S2 -> WS : getLatestWeatherData()

    WS -> REPO : findTopByOrderByRegisteredAtDesc()
    REPO --> WS : Optional<WeatherData>
    WS --> S2 : WeatherData (o vacío)

    alt alertCondition == true
        S2 -> AS : sendAlert(weatherData)
        AS -> MAIL : send(SimpleMailMessage)
        MAIL --> AS : OK / error de envío

    else condiciones normales o sin datos
        S2 -> S2 : log "Condiciones normales"\n/ "no hay datos"
    end
end

@enduml
